{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/audit-dashboard.html"
    },
    {
      "source": "/audit-dashboard-latest.html",
      "destination": "/audit-dashboard-latest.html"
    },
    {
      "source": "/:path((?!api|audit-dashboard-latest\\.html|assets/|lib/|keyword-tracking-locations-LOCKED\\.json|keyword-tracking-class-LOCKED\\.js|keyword-tracking-class-LOCKED\\.json|public/).*)",
      "destination": "/audit-dashboard.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/gsc-data-cleanup",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/cron/backfill-money-page-timeseries",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/optimisation-backup",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/aigeo/squarespace-revenue-sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/aigeo/stripe-revenue-sync",
      "schedule": "10 7 * * *"
    },
    {
      "path": "/api/cron/ga4-metrics-sync",
      "schedule": "20 7 * * 1"
    },
    {
      "path": "/api/cron/revenue-truth-cache-refresh",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/gbp-brand-demand-sync",
      "schedule": "45 7 * * *"
    },
    {
      "path": "/api/cron/competitor-metrics-collect",
      "schedule": "30 6 * * 0"
    }
  ]
}
